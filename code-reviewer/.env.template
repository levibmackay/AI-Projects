# Get a free Groq key at https://console.groq.com (unlimited-ish, very fast)
GROQ_API_KEY=

# Get a free Gemini key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Ollama runs locally with no key needed. Install at https://ollama.com
# Run: ollama pull llama3.2   (recommended, better quality)
# Or use whatever model you have pulled, e.g. tinyllama, codellama, mistral
OLLAMA_MODEL=llama3.2
